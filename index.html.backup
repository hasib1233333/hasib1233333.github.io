<!-- ═══════════════════════════════════
     PAGE: RESEARCH
═══════════════════════════════════ -->
<div id="page-research" class="page">
  <div class="page-header">
    <div class="pg-num">§ 3.0 — Publications &amp; Research</div>
    <h1>Research Work</h1>
  </div>
  <div class="page-content">
    <div class="sec-num">§ 3.1 — Publications</div>
    <div class="sec-title">Published Papers</div>
    <div class="sec-rule"></div>

    <div class="pub-card">
      <span class="pub-badge">Journal</span>
      <div class="pub-title">Dynamic Path Planning in the Unknown Environment with Mobile Target and Obstacles</div>
      <div class="pub-meta">Md Hasibuzzaman, Gene Eu Jan, Han-Yan Wu &nbsp;·&nbsp; International Journal of Environmental Sciences &nbsp;·&nbsp; pp. 1510–1532, 2025</div>
      <div class="pub-doi"><a href="https://doi.org/10.64252/5xd0p524" target="_blank" rel="noopener">doi: 10.64252/5xd0p524</a></div>
    </div>

    <div class="pub-card">
      <span class="pub-badge preprint">Preprint</span>
      <div class="pub-title">Realization of Skeletonization Based on Wave Propagation with the Enhanced Grassfire and Path Planning Application</div>
      <div class="pub-meta">Md Hasibuzzaman, Gene Eu Jan &nbsp;·&nbsp; SSRN Preprint &nbsp;·&nbsp; 2025</div>
      <div class="pub-doi"><a href="https://dx.doi.org/10.2139/ssrn.5418385" target="_blank" rel="noopener">doi: 10.2139/ssrn.5418385</a></div>
    </div>

    <!-- Animated Researcher · Engineer — NO BOX -->
    <div class="prof-section">
      <img src="PHOTO.jpeg" alt="Md Hasibuzzaman Research" class="prof-photo">
      <div class="prof-info">
        <div class="researcher-animated" id="researcherAnimated" aria-label="Researcher · Engineer"></div>
        <p style="margin-top:.8rem;">Working at the intersection of robotics, computer vision, and artificial intelligence. My research develops mathematically rigorous algorithms for autonomous robot navigation — combining classical topology (Voronoi-based skeleton graphs) with modern wave-propagation path planning to solve real-world navigation challenges in cluttered, unknown environments.</p>
        <div class="badge-group" style="margin-top:1rem;">
          <span class="ieee-badge">Autonomous Robots</span>
          <span class="ieee-badge">Voronoi Diagram</span>
          <span class="ieee-badge">Wave Propagation</span>
          <span class="ieee-badge">Distance Transform</span>
          <span class="ieee-badge">LUT Thinning</span>
        </div>
      </div>
    </div>

    <div class="sec-num" style="margin-top:3rem;">§ 3.2 — Topics</div>
    <div class="sec-title">Research Areas</div>
    <div class="sec-rule"></div>
    <div class="research-topics">
      <div class="topic-card"><div class="topic-num">T-01</div><div class="topic-title">Dynamic Path Planning</div><div class="topic-desc">Navigation for mobile robots in partially known or unknown environments using skeleton-guided wave propagation.</div></div>
      <div class="topic-card"><div class="topic-num">T-02</div><div class="topic-title">EGF Skeletonization</div><div class="topic-desc">Four-stage morphological skeleton: Wave Propagation → Fat Skeleton → 1-Pixel Skeleton → Local Thinning.</div></div>
      <div class="topic-card"><div class="topic-num">T-03</div><div class="topic-title">Collision Avoidance</div><div class="topic-desc">Real-time obstacle avoidance using Euclidean distance fields and connectivity-preserving topology.</div></div>
      <div class="topic-card"><div class="topic-num">T-04</div><div class="topic-title">Image Processing</div><div class="topic-desc">Digital image processing: thresholding, morphology, edge detection applied to autonomous systems.</div></div>
      <div class="topic-card"><div class="topic-num">T-05</div><div class="topic-title">NLP &amp; Graph Theory</div><div class="topic-desc">Mapping network topology to graph representations G(N,E) for machine learning applications.</div></div>
      <div class="topic-card"><div class="topic-num">T-06</div><div class="topic-title">Bioinformatics</div><div class="topic-desc">Computational biology and data analysis applied to biological sequences and structural analysis.</div></div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════
     PAGE: MOE SCHOLARSHIP 2024
═══════════════════════════════════ -->
