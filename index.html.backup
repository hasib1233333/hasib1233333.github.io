<!DOCTYPE html><!-- v2.2 -->
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Md Hasibuzzaman | CS &amp; Robotics Researcher</title>
<link rel="canonical" href="https://mdhasibuzzaman.com/">
<meta name="robots" content="index, follow">
<meta name="description" content="Md Hasibuzzaman — M.E. researcher at Asia University Taiwan, specializing in robotics, path planning, and skeletonization algorithms. MOE Scholarship 2024 recipient.">
<meta property="og:title" content="Md Hasibuzzaman | CS & Robotics Researcher">
<meta property="og:description" content="M.E. candidate at Asia University Taiwan. MOE Scholarship 2024. Robotics, path planning & skeletonization research.">
<meta property="og:url" content="https://mdhasibuzzaman.com/">
<meta property="og:type" content="website">
<link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Source+Code+Pro:wght@300;400;500&family=Source+Sans+3:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --ieee-blue: #00629B;
  --ieee-dark-blue: #003B5C;
  --ieee-light-blue: #0A7EBE;
  --ieee-sky: #00A9E0;
  --ieee-gold: #FFB81C;
  --ieee-orange: #FF6F00;
  --text-dark: #1a1a1a;
  --text-muted: #5a5a5a;
  --border-color: #e0e0e0;
  --bg-light: #f5f7fa;
  --white: #ffffff;
  --shadow-sm: 0 2px 8px rgba(0,98,155,0.08);
  --shadow-md: 0 4px 16px rgba(0,98,155,0.12);
  --shadow-lg: 0 8px 32px rgba(0,98,155,0.16);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;font-size:16px;-webkit-tap-highlight-color:transparent;}
body{background:var(--bg-light);color:var(--text-dark);font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;font-weight:400;line-height:1.6;overflow-x:hidden;}
img{max-width:100%;height:auto;display:block;}
a,button,input,select,textarea,[role="button"]{touch-action:manipulation;-webkit-tap-highlight-color:transparent;}
a{cursor:pointer;}
button{cursor:pointer;}

/* ── TOP BAR ── */
.ieee-topbar{background:linear-gradient(135deg,var(--ieee-dark-blue) 0%,var(--ieee-blue) 100%);color:rgba(255,255,255,0.95);text-align:center;padding:.8rem 1rem;font-size:.9rem;border-bottom:2px solid var(--ieee-gold);position:relative;overflow:hidden;}
.ieee-topbar::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.1),transparent);animation:shine 3s infinite;}
@keyframes shine{0%{left:-100%;}100%{left:200%;}}
.ieee-topbar span{color:var(--ieee-gold);font-weight:700;text-shadow:0 1px 2px rgba(0,0,0,.2);}

/* ── TOOLBAR ── */
.ieee-toolbar{background:var(--white);border-bottom:3px solid var(--ieee-gold);padding:0 2rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:1000;box-shadow:var(--shadow-md);backdrop-filter:blur(10px);flex-wrap:wrap;}
.toolbar-brand{display:flex;align-items:center;gap:.7rem;padding:1.2rem 0;color:var(--ieee-blue);font-size:1.5rem;font-weight:800;flex-shrink:0;letter-spacing:-.5px;}
.brand-dot{width:10px;height:10px;background:var(--ieee-gold);border-radius:50%;animation:pulse 2s infinite;box-shadow:0 0 10px var(--ieee-gold);}
@keyframes pulse{0%,100%{transform:scale(1);opacity:1;}50%{transform:scale(1.3);opacity:.7;}}
.toolbar-tabs{display:flex;align-items:center;overflow-x:auto;scrollbar-width:none;gap:.3rem;}
.toolbar-tabs::-webkit-scrollbar{display:none;}
.tab-btn{background:transparent;border:none;color:var(--text-muted);padding:.9rem 1.3rem;font-size:.95rem;cursor:pointer;transition:all .3s cubic-bezier(.4,0,.2,1);border-radius:8px;white-space:nowrap;font-weight:600;position:relative;min-height:44px;}
.tab-btn::after{content:'';position:absolute;bottom:0;left:50%;width:0;height:3px;background:var(--ieee-gold);transition:all .3s;transform:translateX(-50%);}
.tab-btn:hover{color:var(--ieee-blue);background:rgba(0,98,155,.05);}
.tab-btn:hover::after{width:80%;}
.tab-btn.active{color:var(--white);background:linear-gradient(135deg,var(--ieee-blue),var(--ieee-light-blue));box-shadow:0 4px 12px rgba(0,98,155,.3);}
.tab-btn.active::after{display:none;}
/* Advisor Sub-toolbar */
.advisor-subtoolbar{display:none;width:100%;background:linear-gradient(135deg,rgba(0,98,155,.05),rgba(0,169,224,.05));border-top:2px solid var(--border-color);padding:.8rem 2rem;animation:slideDown .3s ease;}
.advisor-subtoolbar.show{display:block;}
@keyframes slideDown{from{opacity:0;transform:translateY(-10px);}to{opacity:1;transform:translateY(0);}}
.advisor-link{display:inline-flex;align-items:center;gap:.6rem;padding:.7rem 1.5rem;background:linear-gradient(135deg,var(--ieee-blue),var(--ieee-light-blue));color:var(--white);text-decoration:none;border-radius:50px;font-weight:700;font-size:.95rem;transition:all .3s;box-shadow:0 2px 8px rgba(0,98,155,.2);}
.advisor-link:hover{transform:translateY(-2px);box-shadow:0 4px 12px rgba(0,98,155,.4);}
.advisor-link::before{content:'👨‍🏫';margin-right:.3rem;}
/* Hamburger */
.hamburger{display:none;flex-direction:column;justify-content:center;align-items:center;gap:5px;width:40px;height:40px;background:none;border:2px solid var(--border-color);border-radius:8px;cursor:pointer;flex-shrink:0;transition:all .3s;}
.hamburger:hover{border-color:var(--ieee-blue);background:rgba(0,98,155,.05);}
.hamburger span{display:block;width:20px;height:2px;background:var(--ieee-blue);border-radius:2px;transition:all .35s cubic-bezier(.4,0,.2,1);}
.hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.hamburger.open span:nth-child(2){opacity:0;transform:scaleX(0);}
.hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
/* Mobile nav drawer */
.mobile-nav{display:none;position:fixed;top:0;left:0;right:0;bottom:0;z-index:999;background:rgba(0,0,0,.5);backdrop-filter:blur(4px);opacity:0;transition:opacity .3s;pointer-events:none;}
.mobile-nav.open{opacity:1;pointer-events:auto;}
.mobile-nav-drawer{position:absolute;top:0;right:0;width:min(300px,85vw);height:100%;background:var(--white);box-shadow:-4px 0 24px rgba(0,0,0,.2);transform:translateX(100%);transition:transform .35s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;overflow-y:auto;}
.mobile-nav.open .mobile-nav-drawer{transform:translateX(0);}
.mobile-nav-header{padding:1.5rem;border-bottom:3px solid var(--ieee-gold);display:flex;align-items:center;justify-content:space-between;background:linear-gradient(135deg,var(--ieee-dark-blue),var(--ieee-blue));color:var(--white);}
.mobile-nav-title{font-size:1.1rem;font-weight:800;color:var(--white);}
.mobile-nav-close{background:none;border:2px solid rgba(255,255,255,.4);color:var(--white);width:36px;height:36px;border-radius:8px;cursor:pointer;font-size:1.2rem;display:flex;align-items:center;justify-content:center;transition:all .3s;}
.mobile-nav-close:hover{background:rgba(255,255,255,.15);}
.mobile-nav-list{padding:1rem;display:flex;flex-direction:column;gap:.4rem;flex:1;}
.mobile-tab-btn{background:transparent;border:none;color:var(--text-dark);padding:1rem 1.2rem;font-size:1rem;cursor:pointer;border-radius:10px;text-align:left;font-weight:600;transition:all .3s;display:flex;align-items:center;gap:.8rem;width:100%;min-height:52px;}
.mobile-tab-btn::before{content:'';width:8px;height:8px;border-radius:50%;background:var(--border-color);flex-shrink:0;transition:all .3s;}
.mobile-tab-btn:hover{background:rgba(0,98,155,.07);color:var(--ieee-blue);}
.mobile-tab-btn:hover::before{background:var(--ieee-blue);}
.mobile-tab-btn.active{background:linear-gradient(135deg,var(--ieee-blue),var(--ieee-light-blue));color:var(--white);box-shadow:0 4px 12px rgba(0,98,155,.3);}
.mobile-tab-btn.active::before{background:var(--ieee-gold);}
/* Mobile Advisor Submenu */
.mobile-advisor-submenu{display:none;padding-left:2rem;margin-top:.5rem;margin-bottom:.5rem;}
.mobile-advisor-submenu.show{display:block;animation:slideDown .3s ease;}
.mobile-advisor-link{display:flex;align-items:center;gap:.6rem;padding:.8rem 1.2rem;background:linear-gradient(135deg,var(--ieee-blue),var(--ieee-light-blue));color:var(--white);text-decoration:none;border-radius:10px;font-weight:600;font-size:.9rem;transition:all .3s;}
.mobile-advisor-link:hover{background:linear-gradient(135deg,var(--ieee-light-blue),var(--ieee-sky));transform:translateX(5px);}
.mobile-advisor-link::before{content:'👨‍🏫';margin-right:.3rem;}

/* ── ADVISOR PAGE ── */
.advisor-page-hero{background:linear-gradient(135deg,var(--ieee-dark-blue) 0%,#003B5C 60%,#00629B 100%);color:white;padding:4rem 2rem;text-align:center;border-bottom:4px solid var(--ieee-gold);position:relative;overflow:hidden;}
.advisor-page-hero::before{content:'';position:absolute;top:-40%;right:-5%;width:500px;height:500px;background:radial-gradient(circle,rgba(255,184,28,.12),transparent);border-radius:50%;}
.advisor-page-chip{display:inline-flex;align-items:center;gap:.6rem;background:rgba(255,184,28,.2);border:2px solid var(--ieee-gold);color:var(--ieee-gold);padding:.6rem 1.4rem;border-radius:50px;font-size:.95rem;font-weight:800;margin-bottom:1.4rem;backdrop-filter:blur(8px);}
.advisor-page-title{font-size:clamp(2rem,5vw,3rem);font-weight:900;margin-bottom:.5rem;text-shadow:2px 2px 8px rgba(0,0,0,.3);}
.advisor-page-sub{color:rgba(255,255,255,.85);font-size:1rem;}
.advisor-content{padding:4rem 2rem;max-width:1100px;margin:0 auto;}
.advisor-profile-card{display:grid;grid-template-columns:280px 1fr;gap:3rem;background:var(--white);border:3px solid var(--border-color);border-radius:24px;overflow:hidden;box-shadow:var(--shadow-lg);position:relative;}
.advisor-profile-card::before{content:'';position:absolute;top:0;left:0;right:0;height:6px;background:linear-gradient(90deg,var(--ieee-blue),var(--ieee-gold),var(--ieee-orange));}
.advisor-photo-col{background:linear-gradient(180deg,#f0f4f8,#e8edf2);display:flex;flex-direction:column;align-items:center;padding:2.5rem 1.5rem;gap:1.5rem;}
.advisor-photo{width:200px;height:200px;object-fit:cover;object-position:center top;border-radius:50%;border:4px solid var(--ieee-gold);box-shadow:0 8px 32px rgba(0,98,155,.25);}
.advisor-name-block{text-align:center;}
.advisor-name{font-size:1.3rem;font-weight:900;color:var(--ieee-dark-blue);line-height:1.2;margin-bottom:.3rem;}
.advisor-title-label{font-size:.85rem;color:var(--ieee-blue);font-weight:700;margin-bottom:.5rem;}
.advisor-univ{font-size:.8rem;color:var(--text-muted);}
.advisor-ext-link{display:inline-flex;align-items:center;gap:.5rem;padding:.6rem 1.2rem;background:linear-gradient(135deg,var(--ieee-blue),var(--ieee-light-blue));color:white;text-decoration:none;border-radius:50px;font-size:.82rem;font-weight:700;transition:all .3s;box-shadow:0 2px 8px rgba(0,98,155,.25);}
.advisor-ext-link:hover{transform:translateY(-2px);box-shadow:0 4px 14px rgba(0,98,155,.4);}
.advisor-bio-col{padding:2.5rem 2.5rem 2.5rem 0;}
.advisor-bio-col h2{font-size:1.5rem;font-weight:900;color:var(--ieee-dark-blue);margin-bottom:1rem;padding-bottom:.8rem;border-bottom:3px solid var(--ieee-gold);}
.advisor-bio-text{font-size:1rem;color:var(--text-muted);line-height:1.85;margin-bottom:1.5rem;}
.advisor-stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1.8rem;}
.advisor-stat{background:linear-gradient(135deg,var(--ieee-blue),var(--ieee-light-blue));color:white;padding:1.2rem;border-radius:14px;text-align:center;box-shadow:var(--shadow-sm);}
.advisor-stat-num{font-size:1.8rem;font-weight:900;color:var(--ieee-gold);line-height:1;}
.advisor-stat-lbl{font-size:.78rem;color:rgba(255,255,255,.9);margin-top:.3rem;font-weight:600;}
.advisor-research-tags{display:flex;flex-wrap:wrap;gap:.5rem;}
.advisor-tag{display:inline-block;background:rgba(0,98,155,.1);color:var(--ieee-blue);border:1.5px solid rgba(0,98,155,.25);padding:.3rem .9rem;border-radius:50px;font-size:.8rem;font-weight:700;}
@media(max-width:800px){
  .advisor-profile-card{grid-template-columns:1fr;}
  .advisor-photo-col{padding:2rem 1.5rem 1.5rem;}
  .advisor-bio-col{padding:0 1.5rem 2rem;}
  .advisor-bio-col h2{margin-top:0;}
  .advisor-content{padding:2.5rem 1.2rem;}
}
@media(max-width:480px){
  .advisor-stats-row{grid-template-columns:repeat(2,1fr);}
  .advisor-photo{width:160px;height:160px;}
  .advisor-name{font-size:1.15rem;}
}

/* ── PAGE SYSTEM ── */
.page{display:none;min-height:calc(100vh - 76px);animation:pageIn .35s ease;}
.page.active{display:block;}
@keyframes pageIn{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}

/* ── DEVICE NOTICE ── */
.device-notice{background:#fff5f5;border-bottom:1.5px solid #fca5a5;padding:.38rem 1rem;animation:noticeGlow 3s ease-in-out infinite;}
@keyframes noticeGlow{0%,100%{background:#fff5f5;}50%{background:#ffe4e4;}}
.device-notice-inner{display:flex;align-items:center;justify-content:center;gap:.5rem;flex-wrap:wrap;}
.device-notice-badge{background:#ef4444;color:#fff;padding:.15rem .6rem;border-radius:50px;font-size:.72rem;font-weight:800;white-space:nowrap;flex-shrink:0;animation:badgePulse 2.5s ease-in-out infinite;}
@keyframes badgePulse{0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,.35);}50%{box-shadow:0 0 0 4px rgba(239,68,68,0);}}
.device-notice-icon{font-size:.9rem;animation:bellShake 2.5s ease-in-out infinite;flex-shrink:0;}
@keyframes bellShake{0%,60%,100%{transform:rotate(0);}10%{transform:rotate(-14deg);}20%{transform:rotate(14deg);}30%{transform:rotate(-8deg);}40%{transform:rotate(8deg);}50%{transform:rotate(0);}}
.device-notice-text{color:#b91c1c;font-size:.78rem;font-weight:600;line-height:1.3;}
.device-notice-text strong{font-weight:800;}

/* ── WELCOME BANNER ── */
.welcome-banner{background:linear-gradient(90deg,var(--ieee-sky),var(--ieee-light-blue),var(--ieee-blue));color:var(--white);text-align:center;padding:1rem;font-size:.95rem;border-bottom:2px solid var(--ieee-gold);position:relative;overflow:hidden;}
.welcome-banner::after{content:'';position:absolute;top:0;left:-50%;width:50%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.15),transparent);animation:shimmer 4s infinite;}
@keyframes shimmer{0%{left:-50%;}100%{left:150%;}}
.welcome-wave{display:inline-block;margin-right:.5rem;animation:wave 2.5s infinite;transform-origin:70% 70%;}
@keyframes wave{0%,100%{transform:rotate(0deg);}10%{transform:rotate(14deg);}20%{transform:rotate(-8deg);}30%{transform:rotate(14deg);}40%{transform:rotate(-4deg);}50%{transform:rotate(10deg);}60%{transform:rotate(0deg);}}

/* ── HERO ── */
.hero-section{background:linear-gradient(135deg,var(--ieee-dark-blue) 0%,var(--ieee-blue) 50%,var(--ieee-light-blue) 100%);color:var(--white);padding:5rem 2rem 4rem;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;max-width:1400px;margin:0 auto;position:relative;overflow:hidden;}
.hero-section::before{content:'';position:absolute;top:-50%;right:-10%;width:600px;height:600px;background:radial-gradient(circle,rgba(255,184,28,.15),transparent);border-radius:50%;animation:float 20s infinite;}
@keyframes float{0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(-30px,30px) scale(1.1);}}
.hero-section canvas{position:absolute;inset:0;pointer-events:none;opacity:.3;}
.ieee-watermark{position:absolute;right:-2rem;bottom:-4rem;font-size:clamp(8rem,15vw,12rem);font-weight:900;color:rgba(255,255,255,.03);letter-spacing:-.05em;pointer-events:none;user-select:none;}
.hero-left{position:relative;z-index:1;}
.hero-welcome-chip{display:inline-flex;align-items:center;gap:.6rem;background:rgba(255,184,28,.2);border:2px solid var(--ieee-gold);color:var(--ieee-gold);padding:.6rem 1.2rem;font-size:.9rem;border-radius:50px;margin-bottom:1.5rem;font-weight:700;backdrop-filter:blur(10px);animation:slideInLeft .8s ease;}
@keyframes slideInLeft{from{opacity:0;transform:translateX(-30px);}to{opacity:1;transform:translateX(0);}}
.hero-name{font-size:clamp(2rem,5vw,3.5rem);font-weight:900;line-height:1.1;margin-bottom:.8rem;color:var(--white);text-shadow:2px 2px 4px rgba(0,0,0,.2);animation:slideInLeft .8s ease .1s both;}
.hero-name-hl{color:var(--ieee-gold);position:relative;display:inline-block;}
.hero-name-hl::after{content:'';position:absolute;bottom:-5px;left:0;width:100%;height:3px;background:var(--ieee-gold);animation:expand 1s ease .5s both;}
@keyframes expand{from{width:0;}to{width:100%;}}
.hero-magic-wrap{font-size:clamp(1.1rem,2vw,1.5rem);color:rgba(255,255,255,.9);margin-bottom:1.5rem;display:flex;align-items:center;gap:.5rem;min-height:2.5rem;animation:slideInLeft .8s ease .2s both;}
.magic-prefix{color:rgba(255,255,255,.8);}
.magic-word{color:var(--ieee-gold);border-right:3px solid var(--ieee-gold);padding-right:8px;font-weight:700;min-width:180px;}
.hero-desc{font-size:clamp(.95rem,1.5vw,1.05rem);color:rgba(255,255,255,.85);line-height:2;margin-bottom:2rem;max-width:520px;animation:slideInLeft .8s ease .3s both;text-align:left;}
.hero-cta{display:flex;gap:1rem;flex-wrap:wrap;animation:slideInLeft .8s ease .4s both;}
.hero-right{display:flex;flex-direction:column;align-items:center;gap:2rem;position:relative;z-index:1;animation:slideInRight .8s ease .2s both;}
@keyframes slideInRight{from{opacity:0;transform:translateX(30px);}to{opacity:1;transform:translateX(0);}}
.profile-ring{position:relative;width:clamp(220px,25vw,320px);height:clamp(220px,25vw,320px);}
.profile-ring::before{content:'';position:absolute;inset:-12px;border-radius:50%;border:3px solid var(--ieee-gold);border-top-color:transparent;border-right-color:transparent;animation:spin 8s linear infinite;}
.profile-ring::after{content:'';position:absolute;inset:-24px;border-radius:50%;border:2px solid rgba(255,184,28,.3);animation:spin 15s linear infinite reverse;}
@keyframes spin{from{transform:rotate(0deg);}to{transform:rotate(360deg);}}
.profile-photo{width:100%;height:100%;border-radius:50%;object-fit:cover;object-position:top;border:5px solid rgba(255,255,255,.2);box-shadow:0 8px 32px rgba(0,0,0,.3);}
.hero-stats{display:grid;grid-template-columns:1fr 1fr;gap:1rem;width:100%;max-width:320px;}
.stat-card{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);padding:1.5rem;text-align:center;border-radius:12px;backdrop-filter:blur(10px);transition:all .3s;position:relative;overflow:hidden;}
.stat-card::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.1),transparent);transition:left .6s;}
.stat-card:hover{background:rgba(255,255,255,.15);transform:translateY(-5px);box-shadow:0 8px 24px rgba(0,0,0,.2);}
.stat-card:hover::before{left:100%;}
.stat-num{font-size:2.2rem;font-weight:900;color:var(--ieee-gold);line-height:1;margin-bottom:.5rem;text-shadow:0 2px 4px rgba(0,0,0,.2);}
.stat-label{font-size:.85rem;color:rgba(255,255,255,.8);line-height:1.3;}

/* ── HERO KEYWORDS ── */
.hero-keywords{display:flex;flex-direction:column;gap:.75rem;width:100%;max-width:320px;}
.hk-tag{font-size:.95rem;font-weight:700;padding:.75rem 1.5rem;border-radius:50px;border:2px solid transparent;cursor:default;letter-spacing:.03em;opacity:0;transform:translateX(20px);transition:opacity .4s ease,transform .4s ease,background .6s ease,border-color .6s ease,color .6s ease,box-shadow .6s ease;width:100%;text-align:left;display:block;}
.hk-tag.show{opacity:1;transform:translateX(0);}
.hk-tag:hover{transform:translateX(6px) !important;box-shadow:0 0 20px rgba(255,255,255,.15);}
@keyframes hkFloat{0%,100%{transform:translateX(0);}50%{transform:translateX(5px);}}
.hk-c1{background:rgba(0,169,224,.12);border-color:#00A9E0;color:#00d4ff;box-shadow:0 0 10px rgba(0,169,224,.2);animation:hkFloat 4s ease-in-out infinite;}
.hk-c2{background:rgba(0,200,220,.12);border-color:#00c8dc;color:#5ee8f5;box-shadow:0 0 10px rgba(0,200,220,.2);animation:hkFloat 4.4s ease-in-out .2s infinite;}
.hk-c3{background:rgba(80,220,80,.12);border-color:#50dc50;color:#7fff7f;box-shadow:0 0 10px rgba(80,220,80,.2);animation:hkFloat 3.8s ease-in-out .4s infinite;}
.hk-c4{background:rgba(200,80,220,.12);border-color:#c850dc;color:#e090f5;box-shadow:0 0 10px rgba(200,80,220,.2);animation:hkFloat 4.2s ease-in-out .6s infinite;}
.hk-c5{background:rgba(255,140,0,.12);border-color:#ff8c00;color:#ffb347;box-shadow:0 0 10px rgba(255,140,0,.2);animation:hkFloat 4.6s ease-in-out .8s infinite;}
.hk-c6{background:rgba(0,169,224,.12);border-color:#00A9E0;color:#00d4ff;box-shadow:0 0 10px rgba(0,169,224,.2);animation:hkFloat 4s ease-in-out 1s infinite;}

/* ── HERO QUOTE ── */
.hero-quote{margin-top:2rem;position:relative;padding-left:1.5rem;animation:slideInLeft .8s ease .4s both;}
.hero-quote-mark{font-family:'Georgia','Times New Roman',serif;font-size:5rem;line-height:.6;color:var(--ieee-gold);opacity:.7;margin-bottom:.4rem;display:block;animation:quotePulse 3s ease-in-out infinite;}
@keyframes quotePulse{0%,100%{opacity:.7;text-shadow:none;}50%{opacity:1;text-shadow:0 0 20px rgba(255,184,28,.6);}}
.hero-quote-text{font-family:'Georgia','Times New Roman',serif;font-size:clamp(1rem,2vw,1.25rem);font-style:italic;font-weight:400;color:rgba(255,255,255,.95);line-height:1.8;letter-spacing:.02em;margin:0;padding:0;border:none;background:none;position:relative;min-height:2.5rem;}
.hero-quote-text::before{content:'';position:absolute;left:-1.5rem;top:0;bottom:0;width:3px;background:linear-gradient(180deg,var(--ieee-gold),rgba(255,184,28,.2));border-radius:2px;}
.quote-word{display:inline-block;opacity:0;transform:translateY(12px);transition:opacity .4s ease,transform .4s ease;margin-right:.28em;}
.quote-word.visible{opacity:1;transform:translateY(0);}
.quote-cursor{display:inline-block;width:2px;height:1.1em;background:var(--ieee-gold);margin-left:2px;vertical-align:middle;animation:cursorBlink .7s steps(1) infinite;}
@keyframes cursorBlink{0%,100%{opacity:1;}50%{opacity:0;}}
.hero-quote-line{margin-top:1rem;height:1px;width:0;background:linear-gradient(90deg,var(--ieee-gold),transparent);border-radius:2px;transition:width 1s ease 0s;}
.hero-quote-line.expanded{width:60px;}

/* ── BUTTONS ── */
.btn-ieee{text-decoration:none;padding:.85rem 1.8rem;font-size:.95rem;cursor:pointer;border:none;transition:all .3s cubic-bezier(.4,0,.2,1);display:inline-flex;align-items:center;gap:.6rem;border-radius:50px;font-weight:700;position:relative;overflow:hidden;}
.btn-ieee::before{content:'';position:absolute;top:50%;left:50%;width:0;height:0;border-radius:50%;background:rgba(255,255,255,.3);transition:width .6s,height .6s,top .6s,left .6s;transform:translate(-50%,-50%);}
.btn-ieee:hover::before{width:300px;height:300px;}
.btn-ieee span{position:relative;z-index:1;}
.btn-primary{background:linear-gradient(135deg,var(--ieee-gold),var(--ieee-orange));color:var(--white);box-shadow:0 4px 15px rgba(255,184,28,.4);}
.btn-primary:hover{transform:translateY(-3px);box-shadow:0 6px 20px rgba(255,184,28,.5);}
.btn-outline{background:transparent;color:var(--white);border:2px solid rgba(255,255,255,.5);backdrop-filter:blur(10px);}
.btn-outline:hover{background:rgba(255,255,255,.1);border-color:var(--white);}
.btn-linkedin{background:#0077B5;color:white;box-shadow:0 4px 15px rgba(0,119,181,.3);}
.btn-linkedin:hover{background:#005885;transform:translateY(-3px);box-shadow:0 6px 20px rgba(0,119,181,.4);}

/* ── SECTION TYPOGRAPHY ── */
.page-header{background:linear-gradient(135deg,var(--ieee-dark-blue) 0%,var(--ieee-blue) 100%);color:var(--white);padding:4rem 2rem;border-bottom:4px solid var(--ieee-gold);position:relative;overflow:hidden;}
.page-header::before{content:'';position:absolute;top:-50%;right:-20%;width:500px;height:500px;background:radial-gradient(circle,rgba(255,184,28,.1),transparent);border-radius:50%;}
.page-header .pg-num{font-size:.9rem;color:var(--ieee-gold);margin-bottom:.7rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;}
.page-header h1{font-size:clamp(2rem,5vw,3rem);font-weight:900;color:var(--white);text-shadow:2px 2px 4px rgba(0,0,0,.2);position:relative;}
.page-content{padding:4rem 2rem;max-width:1400px;margin:0 auto;}
.sec-num{font-size:.9rem;color:var(--ieee-blue);margin-bottom:.7rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;}
.sec-title{font-size:clamp(1.5rem,3vw,2.2rem);font-weight:800;color:var(--ieee-dark-blue);margin-bottom:1rem;position:relative;display:inline-block;}
.sec-title::after{content:'';position:absolute;bottom:-5px;left:0;width:60px;height:4px;background:linear-gradient(90deg,var(--ieee-gold),var(--ieee-orange));border-radius:2px;}
.sec-rule{height:2px;background:linear-gradient(90deg,var(--ieee-gold),transparent);margin-bottom:2.5rem;}

/* ── HOME INFO ── */
.home-info{padding:4rem 2rem;background:var(--white);max-width:1400px;margin:0 auto;}
.research-topics{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:2rem;margin-top:2rem;}
.topic-card{background:var(--white);border:2px solid var(--border-color);border-radius:16px;padding:2rem;transition:all .4s cubic-bezier(.4,0,.2,1);box-shadow:var(--shadow-sm);position:relative;overflow:hidden;}
.topic-card::before{content:'';position:absolute;top:0;left:0;width:100%;height:4px;background:linear-gradient(90deg,var(--ieee-blue),var(--ieee-sky));transform:scaleX(0);transform-origin:left;transition:transform .4s;}
.topic-card:hover{border-color:var(--ieee-blue);box-shadow:var(--shadow-lg);transform:translateY(-8px);}
.topic-card:hover::before{transform:scaleX(1);}
.topic-num{font-size:.85rem;color:var(--ieee-gold);margin-bottom:.7rem;font-weight:800;letter-spacing:1px;}
.topic-title{font-weight:800;font-size:1.2rem;color:var(--ieee-dark-blue);margin-bottom:.7rem;line-height:1.3;}
.topic-desc{font-size:1rem;color:var(--text-muted);line-height:1.7;}

/* ── ABOUT ── */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:stretch;grid-auto-rows:1fr;}
.about-text{display:flex;flex-direction:column;background:var(--white);border:2px solid var(--border-color);border-radius:20px;padding:2.5rem;box-shadow:var(--shadow-md);transition:all .3s;min-height:100%;}
.about-text:hover{border-color:var(--ieee-blue);box-shadow:var(--shadow-lg);transform:translateY(-5px);}
.about-text p{color:var(--text-muted);margin-bottom:1.2rem;font-size:1.05rem;line-height:1.8;text-align:justify;}
.about-text p:last-of-type{margin-bottom:1.5rem;}
.badge-group{display:flex;flex-wrap:wrap;gap:.7rem;margin-top:auto;}
.ieee-badge{font-size:.9rem;padding:.5rem 1rem;border:2px solid var(--ieee-blue);color:var(--ieee-blue);background:rgba(0,98,155,.05);border-radius:50px;font-weight:700;transition:all .3s;}
.ieee-badge:hover{background:var(--ieee-blue);color:var(--white);transform:translateY(-2px);box-shadow:0 4px 12px rgba(0,98,155,.3);}
.contact-block{background:linear-gradient(135deg,var(--ieee-dark-blue),var(--ieee-blue));color:var(--white);padding:2.5rem;border-radius:20px;box-shadow:var(--shadow-lg);position:relative;overflow:hidden;display:flex;flex-direction:column;border:2px solid transparent;transition:all .3s;min-height:100%;height:100%;}
.contact-block:hover{border-color:var(--ieee-gold);transform:translateY(-5px);box-shadow:0 8px 32px rgba(0,98,155,.4);}
.contact-block::before{content:'';position:absolute;top:-50%;right:-50%;width:300px;height:300px;background:radial-gradient(circle,rgba(255,184,28,.15),transparent);border-radius:50%;animation:float 20s infinite;}
.contact-block h3{font-size:1.3rem;color:var(--ieee-gold);margin-bottom:1.5rem;padding-bottom:.8rem;border-bottom:2px solid rgba(255,184,28,.3);font-weight:800;position:relative;}
.contact-items-wrapper{flex:1;display:flex;flex-direction:column;gap:1rem;}
.contact-item{position:relative;}
.c-label{font-size:.85rem;color:rgba(255,255,255,.7);margin-bottom:.4rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;display:flex;align-items:center;gap:.5rem;}
.c-label::before{content:'▸';color:var(--ieee-gold);font-size:1rem;}
.c-val{font-size:1rem;color:var(--white);font-weight:600;padding-left:1.5rem;}
.c-val a{color:var(--ieee-gold);text-decoration:none;transition:all .3s;position:relative;}
.c-val a::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:2px;background:var(--ieee-gold);transition:width .3s;}
.c-val a:hover{color:var(--white);}
.c-val a:hover::after{width:100%;}
.linkedin-btn{display:inline-flex;align-items:center;justify-content:center;gap:.6rem;background:#0077B5;color:white;text-decoration:none;padding:.8rem 1.5rem;font-size:.95rem;border-radius:50px;margin-top:auto;transition:all .3s;font-weight:700;box-shadow:0 4px 15px rgba(0,119,181,.3);position:relative;overflow:hidden;}
.linkedin-btn::before{content:'';position:absolute;top:50%;left:50%;width:0;height:0;background:rgba(255,255,255,.2);border-radius:50%;transition:width .4s,height .4s,top .4s,left .4s;transform:translate(-50%,-50%);}
.linkedin-btn:hover::before{width:300px;height:300px;}
.linkedin-btn:hover{background:#005885;transform:translateY(-3px);box-shadow:0 6px 20px rgba(0,119,181,.5);}

/* ── RESEARCH ── */
.pub-card{border:2px solid var(--border-color);border-left:5px solid var(--ieee-blue);padding:2rem;background:var(--white);margin-bottom:1.5rem;border-radius:12px;box-shadow:var(--shadow-sm);transition:all .3s cubic-bezier(.4,0,.2,1);position:relative;overflow:hidden;}
.pub-card::before{content:'';position:absolute;top:0;left:0;width:5px;height:100%;background:linear-gradient(180deg,var(--ieee-blue),var(--ieee-sky));transition:width .3s;}
.pub-card:hover{border-color:var(--ieee-blue);box-shadow:var(--shadow-lg);transform:translateX(8px);}
.pub-card:hover::before{width:100%;}
.pub-badge{display:inline-block;font-size:.85rem;padding:.4rem 1rem;background:linear-gradient(135deg,var(--ieee-blue),var(--ieee-light-blue));color:white;border-radius:50px;margin-bottom:1rem;font-weight:800;box-shadow:0 2px 8px rgba(0,98,155,.3);position:relative;z-index:1;}
.pub-badge.preprint{background:linear-gradient(135deg,var(--text-muted),#8a8a8a);}
.pub-title{font-size:1.2rem;font-weight:800;line-height:1.5;margin-bottom:.7rem;color:var(--ieee-dark-blue);position:relative;z-index:1;}
.pub-meta{font-size:.95rem;color:var(--text-muted);margin-bottom:.7rem;position:relative;z-index:1;}
.pub-doi a{font-size:.95rem;color:var(--ieee-blue);text-decoration:none;font-weight:700;position:relative;z-index:1;transition:all .3s;}
.pub-doi a:hover{color:var(--ieee-gold);text-decoration:underline;}

/* ── ANIMATED RESEARCHER ENGINEER ── */
.researcher-animated{font-size:clamp(1.5rem,3vw,2rem);font-weight:800;display:flex;flex-wrap:wrap;gap:.3rem;margin-bottom:1rem;color:var(--ieee-dark-blue);}
.researcher-animated .char{display:inline-block;animation:charBounce 2s ease-in-out infinite;}
.ra-w1 .char{color:var(--ieee-dark-blue);}
.ra-w1 .char:nth-child(even){color:var(--ieee-blue);}
.ra-w2 .char{color:var(--ieee-gold);}
.ra-w2 .char:nth-child(even){color:var(--ieee-orange);}
@keyframes charBounce{0%,100%{transform:translateY(0);}50%{transform:translateY(-5px);}}
.ra-dot{color:var(--text-muted);font-size:1.5rem;line-height:1;margin:0 .3rem;}

.prof-section{display:flex;gap:3rem;align-items:flex-start;margin-top:3rem;padding-top:3rem;border-top:3px solid var(--border-color);}
.prof-photo{width:300px;flex-shrink:0;height:220px;object-fit:cover;object-position:top;border:3px solid var(--ieee-blue);border-radius:16px;box-shadow:var(--shadow-lg);transition:all .3s;}
.prof-photo:hover{transform:scale(1.05);box-shadow:var(--shadow-lg);}
.prof-info p{font-size:1.05rem;color:var(--text-muted);line-height:1.8;}

/* ── TIMELINE ── */
.timeline{position:relative;padding-left:3rem;border-left:3px solid var(--ieee-gold);}
.timeline-item{position:relative;margin-bottom:3rem;}
.timeline-dot{position:absolute;left:-3.5rem;top:.5rem;width:14px;height:14px;border-radius:50%;background:var(--ieee-gold);border:4px solid white;box-shadow:0 0 0 3px var(--ieee-blue),0 4px 12px rgba(0,98,155,.3);animation:pulse 2s infinite;}
.tl-period{font-size:.9rem;color:var(--ieee-blue);margin-bottom:.5rem;font-weight:800;letter-spacing:.5px;text-transform:uppercase;}
.tl-role{font-size:1.3rem;font-weight:800;color:var(--ieee-dark-blue);margin-bottom:.5rem;line-height:1.3;}
.tl-org{font-size:1rem;color:var(--text-muted);margin-bottom:1rem;font-weight:600;}
.tl-desc{font-size:1rem;color:var(--text-muted);line-height:1.8;}
.tl-desc li{margin-left:1.5rem;margin-bottom:.5rem;}

/* ── EDUCATION ── */
.edu-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,400px),1fr));gap:2rem;margin-bottom:3rem;}
.edu-card{background:var(--white);border:2px solid var(--border-color);border-radius:16px;padding:2rem;transition:all .3s;box-shadow:var(--shadow-sm);position:relative;overflow:hidden;}
.edu-card::before{content:'';position:absolute;top:0;left:0;width:100%;height:5px;background:linear-gradient(90deg,var(--ieee-blue),var(--ieee-gold));transform:scaleX(0);transform-origin:left;transition:transform .3s;}
.edu-card:hover{border-color:var(--ieee-blue);box-shadow:var(--shadow-lg);transform:translateY(-5px);}
.edu-card:hover::before{transform:scaleX(1);}
.edu-degree{font-size:1.2rem;font-weight:800;color:var(--ieee-dark-blue);margin-bottom:.7rem;line-height:1.3;}
.edu-school{font-size:1rem;color:var(--text-muted);margin-bottom:1rem;font-weight:600;}
.edu-meta{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.7rem;}
.edu-gpa{font-size:.95rem;color:var(--ieee-gold);font-weight:800;background:rgba(255,184,28,.1);padding:.4rem .8rem;border-radius:50px;}
.edu-period{font-size:.9rem;color:var(--text-muted);font-weight:600;}
.exchange-list{display:flex;flex-direction:column;gap:1rem;}
.exchange-item{display:flex;justify-content:space-between;align-items:center;padding:1.2rem 1.5rem;border:2px solid var(--border-color);background:var(--white);border-radius:12px;flex-wrap:wrap;gap:.7rem;font-size:1rem;box-shadow:var(--shadow-sm);transition:all .3s;}
.exchange-item:hover{border-color:var(--ieee-blue);box-shadow:var(--shadow-md);transform:translateX(5px);}
.exchange-period{font-size:.9rem;color:var(--ieee-blue);white-space:nowrap;font-weight:800;background:rgba(0,98,155,.1);padding:.4rem .8rem;border-radius:50px;}

/* ── SKILLS ── */
.skills-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,300px),1fr));gap:2rem;}
.skill-group{background:var(--white);border:2px solid var(--border-color);border-radius:16px;padding:2rem;box-shadow:var(--shadow-sm);transition:all .3s;position:relative;overflow:hidden;}
.skill-group::before{content:'';position:absolute;top:0;left:0;width:100%;height:5px;background:linear-gradient(90deg,var(--ieee-blue),var(--ieee-sky));transform:scaleX(0);transform-origin:left;transition:transform .3s;}
.skill-group:hover{border-color:var(--ieee-blue);box-shadow:var(--shadow-lg);transform:translateY(-5px);}
.skill-group:hover::before{transform:scaleX(1);}
.skill-group h3{font-size:1.2rem;color:var(--ieee-dark-blue);margin-bottom:1.2rem;padding-bottom:.7rem;border-bottom:2px solid var(--border-color);font-weight:800;}
.skill-list{list-style:none;}
.skill-list li{display:flex;align-items:center;gap:.7rem;padding:.7rem 0;font-size:1rem;color:var(--text-dark);border-bottom:1px solid var(--border-color);transition:all .3s;font-weight:600;}
.skill-list li:last-child{border-bottom:none;}
.skill-list li:hover{color:var(--ieee-blue);transform:translateX(5px);}
.skill-list li::before{content:'●';color:var(--ieee-gold);font-size:1rem;flex-shrink:0;font-weight:900;}

/* ── MOE SCHOLARSHIP ── */
.moe-hero{background:linear-gradient(135deg,var(--ieee-dark-blue) 0%,#8B0000 100%);color:white;padding:4rem 2rem;text-align:center;border-bottom:4px solid var(--ieee-gold);position:relative;overflow:hidden;}
.moe-hero::before{content:'★';position:absolute;font-size:clamp(15rem,25vw,20rem);color:rgba(255,184,28,.05);top:-5rem;right:-3rem;pointer-events:none;line-height:1;animation:rotateStar 30s linear infinite;}
@keyframes rotateStar{from{transform:rotate(0deg);}to{transform:rotate(360deg);}}
.moe-award-chip{display:inline-flex;align-items:center;gap:.7rem;background:rgba(255,184,28,.25);border:2px solid var(--ieee-gold);color:var(--ieee-gold);padding:.7rem 1.5rem;font-size:1rem;border-radius:50px;margin-bottom:1.5rem;font-weight:800;backdrop-filter:blur(10px);animation:chipFloat 3s ease-in-out infinite;box-shadow:0 4px 20px rgba(255,184,28,.3);}
@keyframes chipFloat{0%,100%{transform:translateY(0);}50%{transform:translateY(-10px);}}
.moe-title{font-size:clamp(2.2rem,5vw,3.5rem);font-weight:900;margin-bottom:.7rem;text-shadow:2px 2px 8px rgba(0,0,0,.3);}
.moe-subtitle{font-size:clamp(.95rem,2vw,1.1rem);color:rgba(255,255,255,.9);line-height:1.6;}
.moe-content{padding:4rem 2rem;max-width:1400px;margin:0 auto;}

/* Photo Gallery */
.moe-photo-gallery{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,500px),1fr));gap:3rem;margin-bottom:4rem;}
.gallery-card{background:var(--white);border:3px solid var(--border-color);border-radius:20px;overflow:hidden;box-shadow:var(--shadow-md);transition:all .4s cubic-bezier(.4,0,.2,1);position:relative;}
.gallery-card::before{content:'';position:absolute;top:0;left:0;right:0;height:6px;background:linear-gradient(90deg,var(--ieee-blue),var(--ieee-gold),var(--ieee-orange));transform:scaleX(0);transform-origin:left;transition:transform .4s;}
.gallery-card:hover{border-color:var(--ieee-blue);box-shadow:var(--shadow-lg);transform:translateY(-10px);}
.gallery-card:hover::before{transform:scaleX(1);}
.gallery-image-wrap{position:relative;overflow:hidden;aspect-ratio:4/3;background:var(--bg-light);}
.gallery-image{width:100%;height:100%;object-fit:cover;transition:transform .6s cubic-bezier(.4,0,.2,1);}
.gallery-card:hover .gallery-image{transform:scale(1.08);}
.image-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,59,92,.85) 0%,transparent 60%);opacity:0;transition:opacity .4s;display:flex;align-items:flex-end;padding:2rem;}
.gallery-card:hover .image-overlay{opacity:1;}
.overlay-badge{background:linear-gradient(135deg,var(--ieee-gold),var(--ieee-orange));color:var(--white);padding:.6rem 1.2rem;font-size:.9rem;font-weight:800;border-radius:50px;transform:translateY(30px);transition:transform .4s ease .1s;box-shadow:0 4px 15px rgba(255,184,28,.4);}
.gallery-card:hover .overlay-badge{transform:translateY(0);}
.gallery-caption{padding:2rem;background:var(--white);}
.caption-title{font-size:1.2rem;font-weight:800;color:var(--ieee-dark-blue);margin-bottom:1rem;line-height:1.4;}
.caption-meta{display:flex;align-items:center;gap:.6rem;font-size:.95rem;color:var(--text-muted);margin-bottom:.5rem;}
.caption-icon{font-size:1.1rem;}

/* Details Section */
.moe-details-section{background:linear-gradient(135deg,var(--bg-light),var(--white));border-radius:20px;padding:3rem;border:3px solid var(--border-color);box-shadow:var(--shadow-md);}
.moe-details h3{font-size:clamp(1.5rem,3vw,2rem);font-weight:900;color:var(--ieee-dark-blue);margin-bottom:1.5rem;position:relative;padding-bottom:1rem;}
.moe-details h3::after{content:'';position:absolute;bottom:0;left:0;width:100px;height:4px;background:linear-gradient(90deg,var(--ieee-gold),var(--ieee-orange));border-radius:2px;}
.moe-details p{font-size:1.05rem;color:var(--text-muted);line-height:1.8;margin-bottom:1.2rem;}
.moe-list{list-style:none;display:flex;flex-direction:column;gap:1rem;margin:2rem 0;}
.moe-list li{display:flex;gap:1rem;align-items:flex-start;font-size:1rem;color:var(--text-muted);padding:.7rem 0;transition:all .3s;}
.moe-list li:hover{color:var(--ieee-dark-blue);transform:translateX(10px);}
.moe-list li::before{content:'✓';color:var(--ieee-gold);flex-shrink:0;font-weight:900;font-size:1.3rem;width:24px;height:24px;display:flex;align-items:center;justify-content:center;background:rgba(255,184,28,.15);border-radius:50%;}
.moe-stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,200px),1fr));gap:1.5rem;margin-top:2.5rem;}
.moe-stat-card{background:linear-gradient(135deg,var(--ieee-blue),var(--ieee-light-blue));color:white;padding:2rem;text-align:center;border-radius:16px;box-shadow:var(--shadow-md);transition:all .3s;position:relative;overflow:hidden;}
.moe-stat-card::before{content:'';position:absolute;top:-50%;right:-50%;width:200%;height:200%;background:radial-gradient(circle,rgba(255,255,255,.15),transparent);transform:scale(0);transition:transform .6s;}
.moe-stat-card:hover{transform:translateY(-8px);box-shadow:var(--shadow-lg);}
.moe-stat-card:hover::before{transform:scale(1);}
.moe-stat-num{font-size:2.5rem;font-weight:900;color:var(--ieee-gold);line-height:1;margin-bottom:.7rem;text-shadow:0 2px 4px rgba(0,0,0,.2);}
.moe-stat-label{font-size:.9rem;color:rgba(255,255,255,.9);line-height:1.4;font-weight:600;}

/* ── CERTIFICATE & AWARD ── */
.cert-hero{background:linear-gradient(135deg,var(--ieee-dark-blue) 0%,#4a0080 100%);color:white;padding:4rem 2rem;text-align:center;border-bottom:4px solid var(--ieee-gold);position:relative;overflow:hidden;}
.cert-hero::before{content:'🏅';position:absolute;font-size:clamp(10rem,20vw,16rem);opacity:.05;top:-2rem;right:-2rem;pointer-events:none;line-height:1;}
.cert-chip{display:inline-flex;align-items:center;gap:.7rem;background:rgba(255,184,28,.25);border:2px solid var(--ieee-gold);color:var(--ieee-gold);padding:.7rem 1.5rem;font-size:1rem;border-radius:50px;margin-bottom:1.5rem;font-weight:800;backdrop-filter:blur(10px);box-shadow:0 4px 20px rgba(255,184,28,.3);}
.cert-title{font-size:clamp(2rem,5vw,3.2rem);font-weight:900;margin-bottom:.7rem;text-shadow:2px 2px 8px rgba(0,0,0,.3);}
.cert-subtitle{font-size:clamp(.9rem,2vw,1.05rem);color:rgba(255,255,255,.85);line-height:1.6;}
.cert-content{padding:4rem 2rem;max-width:1200px;margin:0 auto;}
.cert-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2rem;}
.cert-card{background:var(--white);border:3px solid var(--border-color);border-radius:20px;overflow:hidden;box-shadow:var(--shadow-md);transition:all .4s cubic-bezier(.4,0,.2,1);position:relative;display:flex;flex-direction:column;}
.cert-card::before{content:'';position:absolute;top:0;left:0;right:0;height:6px;background:linear-gradient(90deg,#4a0080,var(--ieee-gold),var(--ieee-orange));transform:scaleX(0);transform-origin:left;transition:transform .4s;z-index:1;}
.cert-card:hover{border-color:#4a0080;box-shadow:var(--shadow-lg);transform:translateY(-6px);}
.cert-card:hover::before{transform:scaleX(1);}
.cert-img-wrap{position:relative;background:#f0f0f0;overflow:hidden;height:280px;flex-shrink:0;}
.cert-img{width:100%;height:100%;object-fit:cover;object-position:center top;display:block;transition:transform .5s;}
.cert-card:hover .cert-img{transform:scale(1.05);}
.cert-img-overlay{position:absolute;top:0;left:0;right:0;bottom:0;background:linear-gradient(to bottom,transparent 50%,rgba(0,0,0,.5));opacity:0;transition:opacity .4s;}
.cert-card:hover .cert-img-overlay{opacity:1;}
.cert-badge{position:absolute;top:.8rem;left:.8rem;background:linear-gradient(135deg,#4a0080,var(--ieee-blue));color:white;padding:.35rem .9rem;border-radius:50px;font-size:.78rem;font-weight:800;letter-spacing:.5px;box-shadow:0 2px 8px rgba(0,0,0,.3);z-index:2;}
.cert-caption{padding:1.5rem;flex:1;display:flex;flex-direction:column;}
.cert-caption-title{font-size:1.05rem;font-weight:800;color:var(--ieee-dark-blue);margin-bottom:.5rem;line-height:1.35;}
.cert-caption-issuer{font-size:.85rem;color:var(--ieee-blue);font-weight:700;margin-bottom:.6rem;display:flex;align-items:center;gap:.4rem;}
.cert-caption-issuer::before{content:'🏛';font-size:.9rem;}
.cert-caption-date{font-size:.8rem;color:var(--text-muted);margin-bottom:.8rem;display:flex;align-items:center;gap:.4rem;}
.cert-caption-date::before{content:'📅';font-size:.8rem;}
.cert-caption-desc{font-size:.88rem;color:var(--text-muted);line-height:1.65;flex:1;}
.cert-tag{display:inline-block;background:rgba(74,0,128,.1);color:#4a0080;border:1px solid rgba(74,0,128,.25);padding:.2rem .7rem;border-radius:50px;font-size:.75rem;font-weight:700;margin:.2rem .2rem 0 0;}
@media(max-width:900px){.cert-grid{grid-template-columns:repeat(2,1fr);gap:1.5rem;}.cert-img-wrap{height:230px;}}
@media(max-width:600px){.cert-grid{grid-template-columns:1fr;gap:1.5rem;}.cert-content{padding:2.5rem 1rem;}.cert-hero{padding:3rem 1rem;}.cert-title{font-size:2rem;}.cert-img-wrap{height:260px;}.cert-caption{padding:1.2rem;}}
/* ── CERT LIGHTBOX ── */
.cert-img-wrap{cursor:zoom-in;}
.cert-lightbox{display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.92);align-items:center;justify-content:center;padding:1rem;animation:lbIn .25s ease;}
.cert-lightbox.open{display:flex;}
@keyframes lbIn{from{opacity:0;}to{opacity:1;}}
.cert-lightbox-img{max-width:92vw;max-height:92vh;object-fit:contain;border-radius:8px;box-shadow:0 8px 60px rgba(0,0,0,.8);animation:lbScale .25s ease;}
@keyframes lbScale{from{transform:scale(.92);}to{transform:scale(1);}}
.cert-lightbox-close{position:fixed;top:1rem;right:1.2rem;z-index:10000;background:rgba(255,255,255,.15);border:2px solid rgba(255,255,255,.4);color:#fff;width:44px;height:44px;border-radius:50%;font-size:1.4rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s;line-height:1;}
.cert-lightbox-close:hover{background:rgba(255,255,255,.3);}
.cert-lightbox-caption{position:fixed;bottom:1.2rem;z-index:10000;left:50%;transform:translateX(-50%);color:rgba(255,255,255,.85);font-size:.9rem;background:rgba(0,0,0,.55);padding:.5rem 1.2rem;border-radius:50px;white-space:nowrap;max-width:90vw;overflow:hidden;text-overflow:ellipsis;}

/* ── EXPERIMENTS ── */
.exp-hero{background:linear-gradient(135deg,var(--ieee-dark-blue) 0%,#1a2d4d 100%);color:white;padding:4rem 2rem;border-bottom:4px solid var(--ieee-gold);position:relative;overflow:hidden;}
.exp-hero::before{content:'';position:absolute;top:-50%;left:-50%;width:600px;height:600px;background:radial-gradient(circle,rgba(255,184,28,.1),transparent);animation:float 25s infinite;}
.exp-hero .pg-num{font-size:.9rem;color:var(--ieee-gold);margin-bottom:.7rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;}
.exp-hero h1{font-size:clamp(2rem,5vw,3rem);font-weight:900;margin-bottom:.7rem;text-shadow:2px 2px 4px rgba(0,0,0,.2);}
.exp-hero p{color:rgba(255,255,255,.9);font-size:1.05rem;max-width:70ch;line-height:1.8;}
.exp-tags{display:flex;flex-wrap:wrap;gap:.7rem;margin-top:1.2rem;}
.exp-tag{font-size:.9rem;padding:.5rem 1rem;border:2px solid var(--ieee-gold);color:var(--ieee-gold);border-radius:50px;background:rgba(255,184,28,.1);font-weight:700;transition:all .3s;}
.exp-tag:hover{background:var(--ieee-gold);color:var(--white);transform:translateY(-2px);}
.exp-frame-wrap{margin:3rem 2rem;border:3px solid var(--border-color);border-radius:20px;overflow:hidden;box-shadow:var(--shadow-lg);position:relative;max-width:100%;}
.exp-frame-header{background:linear-gradient(135deg,var(--bg-light),var(--white));padding:1rem 1.5rem;display:flex;align-items:center;gap:.6rem;border-bottom:2px solid var(--border-color);}
.dot-win{width:12px;height:12px;border-radius:50%;}
.frame-title{font-size:.9rem;color:var(--text-muted);margin-left:.7rem;font-weight:600;}
.exp-desc{margin:0 2rem 3rem;padding:2.5rem;background:var(--white);border:2px solid var(--border-color);border-radius:20px;box-shadow:var(--shadow-md);}
.algo-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,260px),1fr));gap:2rem;margin-top:2rem;}
/* ── EGF INLINE EMBED ── */
.egf-embed{font-family:system-ui,sans-serif;padding:10px;background:#f5f5f3;overflow-x:hidden;}
.egf-embed button{font-size:11px;padding:3px 9px;border:1px solid #bbb;border-radius:5px;background:#fff;cursor:pointer;white-space:nowrap;font-weight:400;}
.egf-embed button:hover{background:#e0e0e0;}
.egf-embed button.on{background:#1a1a1a;color:#fff;border-color:#1a1a1a;}
.egf-toolbar{display:flex;gap:4px;flex-wrap:wrap;align-items:center;margin-bottom:8px;padding:7px 10px;background:#e8e8e6;border-radius:8px;}
.egf-stage-bar{display:grid;grid-template-columns:repeat(4,1fr);gap:5px;margin-bottom:8px;}
.egf-sbtn{padding:6px 8px;border:1.5px solid #ccc;border-radius:7px;background:#fff;cursor:pointer;text-align:left;}
.egf-sbtn:hover{background:#f5f5f3;}
.egf-sbtn .snum{font-size:11px;font-weight:700;display:block;margin-bottom:2px;}
.egf-sbtn .slbl{font-size:9px;color:#888;display:block;line-height:1.4;}
.egf-sbtn.s1.active{border-color:#4ade80;background:#f0fdf4;}.egf-sbtn.s1.active .snum{color:#14532d;}.egf-sbtn.s1.active .slbl{color:#22c55e;}
.egf-sbtn.s2.active{border-color:#22c55e;background:#dcfce7;}.egf-sbtn.s2.active .snum{color:#14532d;}.egf-sbtn.s2.active .slbl{color:#16a34a;}
.egf-sbtn.s3.active{border-color:#10b981;background:#d1fae5;}.egf-sbtn.s3.active .snum{color:#064e3b;}.egf-sbtn.s3.active .slbl{color:#059669;}
.egf-sbtn.s4.active{border-color:#059669;background:#bbf7d0;}.egf-sbtn.s4.active .snum{color:#064e3b;}.egf-sbtn.s4.active .slbl{color:#047857;}
#egf-cv-wrap{overflow:auto;border-radius:8px;border:2px solid #555;display:block;max-width:100%;width:100%;position:relative;}
#egf-cv{display:block;image-rendering:pixelated;cursor:crosshair;touch-action:none;}
.egf-wrow{display:flex;gap:6px;align-items:center;margin-top:7px;flex-wrap:wrap;}
.egf-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:4px;margin-top:7px;}
.egf-sc{border-radius:5px;padding:4px 7px;}.egf-sc .v{font-size:13px;font-weight:600;}.egf-sc .l{font-size:9px;color:#555;}
.egf-legend{display:flex;gap:7px;flex-wrap:wrap;margin-top:6px;font-size:10px;color:#555;}
.egf-li{display:flex;align-items:center;gap:4px;}
.egf-ls{width:12px;height:12px;border-radius:2px;border:1px solid rgba(0,0,0,.15);flex-shrink:0;}
#egf-insp{margin-top:6px;padding:5px 10px;background:#fff;border:1px solid #ddd;border-radius:6px;font-size:11px;color:#555;min-height:22px;}
.egf-info-box{margin-top:8px;padding:8px 12px;background:#fff;border:1px solid #ddd;border-radius:8px;font-size:11px;line-height:1.7;}
.egf-info-box h4{font-size:12px;font-weight:600;margin-bottom:4px;}
.egf-rule{margin:2px 0;padding:3px 8px;border-radius:4px;}
@media(max-width:768px){
  .egf-embed{padding:10px;}.egf-toolbar{padding:8px 10px;gap:5px;margin-bottom:8px;flex-wrap:wrap;}
  .egf-embed button{font-size:12px;padding:8px 12px;min-height:40px;border-radius:7px;touch-action:manipulation;}
  .egf-stage-bar{grid-template-columns:repeat(2,1fr);gap:6px;margin-bottom:8px;}
  .egf-sbtn{padding:10px 8px;min-height:56px;touch-action:manipulation;}
  .egf-sbtn .snum{font-size:11px;}.egf-sbtn .slbl{font-size:8.5px;}
  .egf-wrow{gap:6px;margin-top:8px;font-size:11px;}
  .egf-wrow input[type=range]{height:32px;}
  .egf-wrow button{min-height:40px;padding:8px 12px;}
  .egf-stats{grid-template-columns:repeat(3,1fr);gap:5px;margin-top:8px;}
  .egf-sc{padding:5px 6px;}.egf-sc .v{font-size:13px;}.egf-sc .l{font-size:9px;}
  .egf-legend{gap:6px;margin-top:6px;font-size:10px;}
  #egf-insp{margin-top:6px;padding:6px 10px;font-size:10px;min-height:28px;}
  .egf-info-box{margin-top:8px;padding:8px 12px;font-size:10.5px;}
}
@media(max-width:480px){
  .egf-embed{padding:8px;}.egf-toolbar{padding:6px 8px;gap:4px;margin-bottom:6px;}
  .egf-embed button{font-size:11px;padding:7px 10px;min-height:38px;}
  .egf-stage-bar{grid-template-columns:repeat(2,1fr);gap:5px;margin-bottom:6px;}
  .egf-sbtn{padding:9px 7px;min-height:52px;}.egf-sbtn .snum{font-size:10px;}.egf-sbtn .slbl{font-size:8px;}
  .egf-wrow{gap:5px;margin-top:6px;font-size:10px;flex-wrap:wrap;}
  .egf-wrow input{max-width:100px!important;}
  .egf-stats{grid-template-columns:repeat(2,1fr);gap:3px;margin-top:4px;}
  .egf-sc{padding:2px 4px;}.egf-sc .v{font-size:11px;}.egf-sc .l{font-size:7px;}
  .egf-legend{gap:4px;margin-top:4px;font-size:8px;flex-wrap:wrap;}
  .egf-li{gap:3px;}.egf-ls{width:10px;height:10px;}
  #egf-insp{margin-top:4px;padding:3px 6px;font-size:9px;}
  .egf-info-box{margin-top:5px;padding:5px 8px;font-size:9px;line-height:1.5;}
}

/* ── EXPERIMENT SUB-NAVIGATION ── */
.exp-subnav{display:flex;gap:.5rem;padding:1rem 2rem;background:var(--bg-light);border-bottom:2px solid var(--border-color);overflow-x:auto;scrollbar-width:thin;}
.exp-subnav-btn{background:var(--white);border:2px solid var(--border-color);color:var(--text-dark);padding:.8rem 1.5rem;font-size:.95rem;cursor:pointer;transition:all .3s;border-radius:10px;white-space:nowrap;font-weight:600;}
.exp-subnav-btn:hover{background:var(--ieee-light-blue);color:var(--white);border-color:var(--ieee-blue);transform:translateY(-2px);}
.exp-subnav-btn.active{background:linear-gradient(135deg,var(--ieee-blue),var(--ieee-light-blue));color:var(--white);border-color:var(--ieee-blue);box-shadow:0 4px 12px rgba(0,98,155,.3);}
.exp-tab-content{display:none;}
.exp-tab-content.active{display:block;}

/* ── ANALYSIS FIGURES ── */
.analysis-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,450px),1fr));gap:2rem;margin-top:2rem;}
.analysis-figure{background:var(--white);border:2px solid var(--border-color);border-radius:12px;overflow:hidden;box-shadow:var(--shadow-md);transition:all .3s;}
.analysis-figure:hover{box-shadow:var(--shadow-lg);transform:translateY(-4px);}
.analysis-figure img{width:100%;height:auto;display:block;}
.fig-caption{padding:1rem;background:var(--bg-light);color:var(--text-dark);font-size:.9rem;font-weight:600;text-align:center;border-top:2px solid var(--border-color);}

/* ── LIVE COMPARISON ── */
.shape-selector{display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:2rem;padding:1rem;background:var(--bg-light);border-radius:12px;}
.shape-btn{background:var(--white);border:2px solid var(--border-color);color:var(--text-dark);padding:.6rem 1.2rem;font-size:.9rem;cursor:pointer;transition:all .3s;border-radius:8px;font-weight:600;}
.shape-btn:hover{background:var(--ieee-light-blue);color:var(--white);border-color:var(--ieee-blue);}
.shape-btn.active{background:var(--ieee-blue);color:var(--white);border-color:var(--ieee-blue);box-shadow:0 2px 8px rgba(0,98,155,.3);}

/* ── MAIN EXPERIMENT CONTENT ── */
.main-exp-content{display:none;}
.main-exp-content.active{display:block;}
.live-comparison-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,200px),1fr));gap:1.5rem;margin-bottom:2rem;}
.live-method{background:var(--white);border:2px solid var(--border-color);border-radius:12px;padding:1rem;text-align:center;box-shadow:var(--shadow-md);}
.live-method h4{font-size:1rem;color:var(--ieee-blue);margin-bottom:.8rem;font-weight:700;}
.live-method canvas{border:2px solid var(--border-color);border-radius:8px;max-width:100%;height:auto;image-rendering:pixelated;}
.method-stats{margin-top:.8rem;font-size:.85rem;color:var(--text-muted);padding:.5rem;background:var(--bg-light);border-radius:6px;}
.computation-info{display:flex;gap:1rem;flex-wrap:wrap;padding:1rem;background:var(--bg-light);border-radius:12px;margin-top:1rem;}
.info-box{flex:1;min-width:200px;padding:.8rem;background:var(--white);border:2px solid var(--border-color);border-radius:8px;font-size:.9rem;}
.info-box strong{color:var(--ieee-blue);display:block;margin-bottom:.3rem;}

/* ── BENCHMARK TABLE ── */
.benchmark-table-wrap{overflow-x:auto;margin:2rem 0;border-radius:12px;box-shadow:var(--shadow-lg);}
.benchmark-table{width:100%;border-collapse:collapse;background:var(--white);font-size:.9rem;}
.benchmark-table thead{background:linear-gradient(135deg,var(--ieee-blue),var(--ieee-light-blue));color:var(--white);}
.benchmark-table th{padding:1rem;text-align:left;font-weight:700;border-bottom:3px solid var(--ieee-gold);}
.benchmark-table .table-header{text-align:center;font-size:1.1rem;padding:1.5rem;}
.benchmark-table td{padding:.8rem 1rem;border-bottom:1px solid var(--border-color);}
.benchmark-table tbody tr:hover{background:var(--bg-light);}
.benchmark-table .section-header{background:var(--bg-light);font-weight:700;color:var(--ieee-blue);}
.benchmark-table .section-header td{padding:.6rem 1rem;font-size:.85rem;}
.benchmark-table .highlight{background:rgba(255,184,28,.1);}
.benchmark-table .highlight td{font-weight:600;}
.benchmark-table .best{color:#059669;font-weight:700;}
.benchmark-summary{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,280px),1fr));gap:1.5rem;margin-top:2rem;}
.summary-card{background:var(--white);border:2px solid var(--border-color);border-radius:12px;padding:1.5rem;box-shadow:var(--shadow-md);}
.summary-card h4{color:var(--ieee-blue);font-size:1.1rem;margin-bottom:1rem;font-weight:700;}
.summary-card ul{list-style:none;padding:0;}
.summary-card li{padding:.5rem 0;border-bottom:1px solid var(--border-color);font-size:.9rem;}
.summary-card li:last-child{border-bottom:none;}
.summary-card strong{color:var(--ieee-gold);font-weight:700;}

@media(max-width:768px){
  .exp-subnav{padding:.8rem 1rem;gap:.4rem;}
  .exp-subnav-btn{padding:.7rem 1rem;font-size:.85rem;}
  .analysis-grid{grid-template-columns:1fr;gap:1.5rem;}
  .shape-selector{gap:.4rem;padding:.8rem;}
  .shape-btn{padding:.5rem 1rem;font-size:.85rem;}
  .live-comparison-grid{grid-template-columns:repeat(2,1fr);gap:1rem;}
  .benchmark-table{font-size:.8rem;}
  .benchmark-table th,.benchmark-table td{padding:.6rem .8rem;}
  .benchmark-summary{grid-template-columns:1fr;gap:1rem;}
}

/* ── CONTACT PAGE ── */
.contact-page-grid{display:grid;grid-template-columns:1fr 380px;gap:3rem;align-items:start;}
.contact-cards{display:flex;flex-direction:column;gap:1.2rem;}
.contact-card{display:flex;align-items:center;gap:1.5rem;padding:1.5rem 2rem;border-radius:16px;text-decoration:none;border:2px solid var(--border-color);background:var(--white);box-shadow:var(--shadow-sm);transition:all .35s cubic-bezier(.4,0,.2,1);position:relative;overflow:hidden;}
.contact-card::before{content:'';position:absolute;left:0;top:0;width:5px;height:100%;transition:width .35s;}
.contact-card:hover{transform:translateX(8px);box-shadow:var(--shadow-lg);}
.contact-card:hover::before{width:100%;}
.contact-card.github::before{background:linear-gradient(180deg,#24292e,#000);}
.contact-card.github:hover{border-color:#24292e;color:#24292e;}
.contact-card.github .contact-card-icon{background:rgba(36,41,46,.1);color:#24292e;}
.contact-card.linkedin::before{background:linear-gradient(180deg,#0077B5,#005885);}
.contact-card.linkedin:hover{border-color:#0077B5;color:#0077B5;}
.contact-card.facebook::before{background:linear-gradient(180deg,#1877F2,#0d5dbf);}
.contact-card.facebook:hover{border-color:#1877F2;color:#1877F2;}
.contact-card.scholar::before{background:linear-gradient(180deg,#4285F4,#1a56c4);}
.contact-card.scholar:hover{border-color:#4285F4;color:#4285F4;}
.contact-card.email::before{background:linear-gradient(180deg,var(--ieee-blue),var(--ieee-light-blue));}
.contact-card.email:hover{border-color:var(--ieee-blue);color:var(--ieee-blue);}
.contact-card.email-school::before{background:linear-gradient(180deg,var(--ieee-dark-blue),var(--ieee-blue));}
.contact-card.email-school:hover{border-color:var(--ieee-dark-blue);color:var(--ieee-dark-blue);}
.contact-card.phone::before{background:linear-gradient(180deg,#2e7d32,#1b5e20);}
.contact-card.phone:hover{border-color:#2e7d32;color:#2e7d32;}
.contact-card-icon{width:56px;height:56px;border-radius:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;z-index:1;transition:all .35s;}
.contact-card.linkedin .contact-card-icon{background:rgba(0,119,181,.1);color:#0077B5;}
.contact-card.facebook .contact-card-icon{background:rgba(24,119,242,.1);color:#1877F2;}
.contact-card.scholar .contact-card-icon{background:rgba(66,133,244,.1);color:#4285F4;}
.contact-card.email .contact-card-icon{background:rgba(0,98,155,.1);color:var(--ieee-blue);}
.contact-card.email-school .contact-card-icon{background:rgba(0,59,92,.1);color:var(--ieee-dark-blue);}
.contact-card.phone .contact-card-icon{background:rgba(46,125,50,.1);color:#2e7d32;}
.contact-card:hover .contact-card-icon{background:rgba(255,255,255,.2);}
.contact-card-body{flex:1;position:relative;z-index:1;}
.contact-card-label{font-size:.85rem;color:var(--text-muted);font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin-bottom:.3rem;transition:color .35s;}
.contact-card-value{font-size:1rem;color:var(--text-dark);font-weight:700;transition:color .35s;}
.contact-card:hover .contact-card-label,.contact-card:hover .contact-card-value{color:inherit;}
.contact-card-arrow{font-size:1.4rem;color:var(--text-muted);position:relative;z-index:1;transition:all .35s;font-weight:700;}
.contact-card:hover .contact-card-arrow{transform:translateX(6px);color:inherit;}
/* Info Panel */
.contact-info-panel{position:sticky;top:90px;}
.contact-info-inner{background:linear-gradient(135deg,var(--ieee-dark-blue),var(--ieee-blue));color:var(--white);border-radius:24px;padding:2.5rem;box-shadow:var(--shadow-lg);text-align:center;position:relative;overflow:hidden;}
.contact-info-inner::before{content:'';position:absolute;top:-50%;right:-50%;width:300px;height:300px;background:radial-gradient(circle,rgba(255,184,28,.15),transparent);border-radius:50%;pointer-events:none;}
.contact-info-avatar{width:110px;height:110px;border-radius:50%;margin:0 auto 1.2rem;border:4px solid var(--ieee-gold);overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,.3);}
.contact-avatar-img{width:100%;height:100%;object-fit:cover;object-position:top;}
.contact-info-name{font-size:1.4rem;font-weight:900;color:var(--white);margin-bottom:.5rem;}
.contact-info-role{font-size:.9rem;color:rgba(255,255,255,.8);line-height:1.6;margin-bottom:1.2rem;}
.contact-info-divider{height:2px;background:linear-gradient(90deg,transparent,rgba(255,184,28,.5),transparent);margin:1.2rem 0;}
.contact-info-note{font-size:.95rem;color:rgba(255,255,255,.85);line-height:1.7;margin-bottom:1.5rem;}
.contact-info-tags{display:flex;flex-wrap:wrap;gap:.6rem;justify-content:center;}
.contact-tag{font-size:.85rem;padding:.4rem .9rem;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);border-radius:50px;color:var(--white);font-weight:600;transition:all .3s;}
.contact-tag:hover{background:rgba(255,184,28,.25);border-color:var(--ieee-gold);}
@media(max-width:1024px){.contact-page-grid{grid-template-columns:1fr;}.contact-info-panel{position:static;}}
@media(max-width:600px){.contact-card{padding:1.2rem 1.2rem;gap:1rem;}.contact-card-icon{width:44px;height:44px;border-radius:10px;}.contact-card-value{font-size:.9rem;word-break:break-all;}}

/* ── FOOTER ── */
footer{background:linear-gradient(135deg,var(--ieee-dark-blue),var(--ieee-blue));color:white;text-align:center;padding:3rem 2rem;font-size:.95rem;border-top:4px solid var(--ieee-gold);position:relative;overflow:hidden;}
footer::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:radial-gradient(circle,rgba(255,184,28,.05),transparent);animation:rotate 30s linear infinite;}
@keyframes rotate{from{transform:rotate(0deg);}to{transform:rotate(360deg);}}
footer .f-name{font-size:1.4rem;font-weight:900;color:var(--ieee-gold);margin-bottom:.7rem;text-shadow:0 2px 4px rgba(0,0,0,.2);position:relative;}
footer a{color:rgba(255,255,255,.9);text-decoration:none;transition:all .3s;position:relative;font-weight:600;}
footer a:hover{color:var(--ieee-gold);text-decoration:underline;}

/* ── ANIMATIONS ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}

/* ── RESPONSIVE ── */
@media(max-width:1024px){
  .hero-section{grid-template-columns:1fr;padding:4rem 2rem 3rem;gap:3rem;text-align:center;}
  .hero-left{display:flex;flex-direction:column;align-items:center;}
  .hero-desc{max-width:100%;}
  .hero-cta{justify-content:center;}
  .hero-right{order:-1;}
  .hero-stats{max-width:400px;}
  .about-grid{grid-template-columns:1fr;align-items:stretch;}
  .about-text{margin-bottom:0;}
  .moe-stats-grid{grid-template-columns:repeat(2,1fr);}
  .edu-grid{grid-template-columns:1fr;}
  .skills-grid{grid-template-columns:repeat(2,1fr);}
  .prof-section{flex-direction:column;align-items:center;}
  .prof-photo{width:100%;max-width:400px;height:280px;}
}

@media(max-width:768px){
  .ieee-toolbar{padding:0 1rem;}
  .toolbar-brand{font-size:1.2rem;padding:.8rem 0;}
  .toolbar-tabs{display:none;}
  .hamburger{display:flex;}
  .mobile-nav{display:block;}
  .hero-section{padding:3rem 1.5rem 2rem;}
  .hero-name{font-size:2rem;}
  .hero-magic-wrap{font-size:1.1rem;flex-direction:column;text-align:center;}
  .magic-word{min-width:auto;}
  .profile-ring{width:200px;height:200px;}
  .hero-stats{grid-template-columns:1fr 1fr;gap:.8rem;}
  .stat-card{padding:1.2rem;}
  .stat-num{font-size:1.8rem;}
  .page-header{padding:3rem 1.5rem;}
  .page-content,.home-info,.moe-content{padding:3rem 1.5rem;}
  .research-topics{grid-template-columns:1fr;gap:1.5rem;}
  .topic-card{padding:1.5rem;}
  .moe-photo-gallery{gap:2rem;}
  .gallery-caption{padding:1.5rem;}
  .moe-details-section{padding:2rem;}
  .moe-stats-grid{grid-template-columns:1fr;gap:1rem;}
  .skills-grid{grid-template-columns:1fr;}
  .skill-group{padding:1.5rem;}
  .edu-card{padding:1.5rem;}
  .timeline{padding-left:2rem;}
  .timeline-dot{left:-2.6rem;}
  .pub-card{padding:1.5rem;}
  .exp-hero{padding:2.5rem 1.5rem;}
  .exp-frame-wrap,.exp-desc{margin:1.5rem;}
  .algo-grid{grid-template-columns:1fr;}
}

@media(max-width:480px){
  .ieee-topbar{font-size:.8rem;padding:.6rem .5rem;}
  .welcome-banner{font-size:.85rem;padding:.8rem .5rem;}
  .toolbar-brand{font-size:1rem;}
  .brand-dot{width:8px;height:8px;}
  .toolbar-tabs{display:none;}
  .hamburger{display:flex;}
  .mobile-nav{display:block;}
  .hero-section{padding:2rem 1rem;}
  .hero-welcome-chip{padding:.5rem 1rem;font-size:.8rem;}
  .hero-name{font-size:1.8rem;}
  .hero-desc{font-size:.95rem;}
  .btn-ieee{padding:.7rem 1.3rem;font-size:.85rem;}
  .profile-ring{width:180px;height:180px;}
  .hero-stats{grid-template-columns:1fr;max-width:250px;}
  .stat-card{padding:1rem;}
  .stat-num{font-size:1.6rem;}
  .stat-label{font-size:.75rem;}
  .page-header{padding:2.5rem 1rem;}
  .page-header h1{font-size:1.8rem;}
  .page-content,.home-info,.moe-content{padding:2.5rem 1rem;}
  .sec-title{font-size:1.5rem;}
  .topic-card{padding:1.2rem;}
  .topic-title{font-size:1.1rem;}
  .moe-hero{padding:3rem 1rem;}
  .moe-title{font-size:2rem;}
  .moe-award-chip{padding:.5rem 1rem;font-size:.85rem;}
  .gallery-caption{padding:1.2rem;}
  .caption-title{font-size:1rem;}
  .moe-details-section{padding:1.5rem;}
  .moe-details h3{font-size:1.5rem;}
  .moe-details p{font-size:.95rem;}
  .moe-list li{font-size:.9rem;}
  .moe-stat-card{padding:1.5rem;}
  .moe-stat-num{font-size:2rem;}
  .edu-card{padding:1.2rem;}
  .edu-degree{font-size:1rem;}
  .skill-group{padding:1.2rem;}
  .skill-group h3{font-size:1rem;}
  .skill-list li{font-size:.9rem;}
  .timeline{padding-left:1.5rem;}
  .timeline-dot{left:-2.3rem;width:10px;height:10px;}
  .tl-role{font-size:1.1rem;}
  .pub-card{padding:1.2rem;}
  .pub-title{font-size:1rem;}
  .exp-frame-wrap,.exp-desc{margin:1rem;}
  .exp-desc{padding:1.5rem;}
  footer{padding:1.5rem 1rem;font-size:.85rem;}
}
</style>
</head>
